{
    "name": "@fermumen/databricks-execute",
    "version": "2.11.0",
    "description": "CLI to sync and execute a local file on Databricks (mirrors VS Code extension runFile behavior).",
    "license": "LicenseRef-LICENSE",
    "homepage": "https://github.com/fermumen/databricks-vscode/tree/main/packages/databricks-execute",
    "bugs": {
        "url": "https://github.com/fermumen/databricks-vscode/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/fermumen/databricks-vscode.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "bin": "dist/cli.js",
    "files": [
        "dist",
        "LICENSE",
        "NOTICE",
        "README.md",
        "example_usage.md"
    ],
    "scripts": {
        "build": "node scripts/build.js",
        "watch": "node scripts/build.js --watch",
        "clean": "rm -rf dist node_modules",
        "fix": "eslint src --ext ts --fix && prettier src README.md package.json tsconfig.json --write",
        "prepack": "node scripts/build.js",
        "test:lint": "eslint src --ext ts && prettier src README.md package.json tsconfig.json -c",
        "test:integ": "node scripts/build.js && node scripts/test-integ.js",
        "test:unit": "node scripts/test.js",
        "test": "yarn run test:lint && yarn run test:unit"
    },
    "dependencies": {
        "google-auth-library": "^10.4.1",
        "ini": "^5.0.0",
        "reflect-metadata": "^0.2.2",
        "semver": "^7.7.2",
        "yaml": "^2.3.4"
    },
    "devDependencies": {
        "@types/node": "^20.10.4",
        "esbuild": "^0.25.0",
        "eslint": "^8.55.0",
        "prettier": "^3.1.1",
        "typescript": "^5.5.0"
    }
}
